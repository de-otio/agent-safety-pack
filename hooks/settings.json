{
  "_comment": "agent-safety-pack Claude Code hooks. Copy to .claude/settings.json or merge with your existing settings.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node node_modules/@de-otio/agent-safety-pack/hooks/pre-bash.js"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node node_modules/@de-otio/agent-safety-pack/hooks/pre-write.js"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "node node_modules/@de-otio/agent-safety-pack/hooks/pre-fetch.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node node_modules/@de-otio/agent-safety-pack/hooks/post-bash.js"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "node node_modules/@de-otio/agent-safety-pack/hooks/post-fetch.js"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node node_modules/@de-otio/agent-safety-pack/hooks/post-write.js"
          }
        ]
      }
    ]
  }
}
